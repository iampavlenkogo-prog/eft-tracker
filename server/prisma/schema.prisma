generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(cuid())
  email                    String               @unique
  password                 String
  firstName                String
  lastName                 String
  latinName                String?
  phone                    String?
  telegram                 String?
  meetingLink              String?
  eftLevel                 EftLevel             @default(BASIC)
  roles                    Role[]
  createdAt                DateTime             @default(now())
  avatarUrl                String?
  resetToken               String?              @unique
  resetTokenExpiry         DateTime?
  notifications            Notification[]
  pushSubscriptions        PushSubscription[]
  seminars                 Seminar[]
  communityPhrases         CommunityPhrase[]
  savedPhrases             SavedPhrase[]
  supervisionsAsSupervisor Supervision[]        @relation("SupervisorSupervisions")
  supervisionsAsTherapist  Supervision[]        @relation("TherapistSupervisions")
  slotsAsSupervisor        SupervisionSlot[]    @relation("SupervisorSlots")
  bookingsAsTherapist      SupervisionBooking[] @relation("BookingTherapist")
  organizedEvents          Event[]              @relation("OrganizerEvents")
  eventRegistrations       EventRegistration[]
  skillsGroupsAsUser            SkillsGroup[]            @relation("UserSkillsGroups")
  skillsGroupsAsSupervisor      SkillsGroup[]            @relation("SupervisorSkillsGroups")
  groupSupervisionsAsSupervisor GroupSupervision[]       @relation("SupervisorGroupSupervisions")
  groupSupervisionsAsPresenter  GroupSupervision[]       @relation("PresenterGroupSupervisions")
  groupParticipations           GroupParticipant[]       @relation("UserGroupParticipations")
  therapistRequests             TherapistRequest[]       @relation("TherapistRequestAuthor")
  therapistResponses            TherapistResponse[]      @relation("TherapistResponseAuthor")
  communityPosts                CommunityPost[]          @relation("CommunityAuthorPosts")
  communityReactions            CommunityReaction[]      @relation("CommunityUserReactions")
  communityComments             CommunityComment[]       @relation("CommunityCommentAuthor")
}

model SupervisionSlot {
  id           String               @id @default(cuid())
  supervisorId String
  date         String
  time         String
  duration     Int
  type         SlotType
  notes        String?
  status       SlotStatus           @default(AVAILABLE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  supervisor   User                 @relation("SupervisorSlots", fields: [supervisorId], references: [id])
  bookings     SupervisionBooking[]
}

model SupervisionBooking {
  id              String          @id @default(cuid())
  slotId          String
  slot            SupervisionSlot @relation(fields: [slotId], references: [id])
  therapistId     String
  therapist       User            @relation("BookingTherapist", fields: [therapistId], references: [id])
  caseTitle       String?
  description     String?
  protocolFileUrl String?
  videoUrl        String?
  comment         String?
  meetingLink     String?
  status          BookingStatus   @default(PENDING)
  reminderSent    Boolean         @default(false)
  staleSent       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Supervision {
  id           String          @id @default(cuid())
  userId       String
  supervisorId String
  date         DateTime
  type         SupervisionType
  status       RecordStatus    @default(PENDING)
  createdAt    DateTime        @default(now())
  hours        Float           @default(1.0)
  supervisor   User            @relation("SupervisorSupervisions", fields: [supervisorId], references: [id])
  user         User            @relation("TherapistSupervisions", fields: [userId], references: [id])
}

model Seminar {
  id             String       @id @default(cuid())
  userId         String
  title          String
  date           DateTime
  hours          Float
  points         Float
  certificateUrl String?
  status         RecordStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EftLevel {
  BASIC
  ADVANCED
  STUDENT
  CERTIFIED
  SUPERVISOR
  SUPERVISOR_CANDIDATE
}

enum Role {
  THERAPIST
  SUPERVISOR
  ADMIN
  SUPERVISOR_CANDIDATE
}

enum SupervisionType {
  INDIVIDUAL_PRESENTER
  INDIVIDUAL_LISTENER
  GROUP_PRESENTER
  GROUP_LISTENER
}

enum RecordStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SlotType {
  INDIVIDUAL
  GROUP
}

enum SlotStatus {
  AVAILABLE
  PENDING
  BOOKED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model Event {
  id                          String              @id @default(cuid())
  organizerId                 String
  organizer                   User                @relation("OrganizerEvents", fields: [organizerId], references: [id])
  title                       String
  description                 String
  date                        DateTime
  startTime                   String?
  endTime                     String?
  price                       Float
  currency                    String              @default("UAH")
  priceVariations             Json?
  maxParticipants             Int?
  coverImageUrl               String?
  paymentInstructions         String
  paymentPurpose              String?
  zoomLink                    String?
  zoomPassword                String?
  presentationUrl             String?
  benefitsList                Json?
  registrationClosed          Boolean             @default(false)
  recordingUrl                String?
  recordingAvailabilityDays   Int?
  recordingExpiresAt          DateTime?
  keepMaterialsAfterRecording Boolean             @default(true)
  status                      EventStatus         @default(DRAFT)
  registrations               EventRegistration[]
  reminders                   EventReminder[]
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

model EventReminder {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sendAt    DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EventRegistration {
  id                String             @id @default(cuid())
  eventId           String
  event             Event              @relation(fields: [eventId], references: [id])
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  status            RegistrationStatus @default(PENDING)
  paymentReceiptUrl String?
  createdAt         DateTime           @default(now())

  @@unique([eventId, userId])
}

model SkillsGroup {
  id           String       @id @default(cuid())
  userId       String
  supervisorId String
  date         DateTime
  hours        Float        @default(1.0)
  status       RecordStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  user         User         @relation("UserSkillsGroups", fields: [userId], references: [id])
  supervisor   User         @relation("SupervisorSkillsGroups", fields: [supervisorId], references: [id])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  PAYMENT_SENT
  RECEIPT_UPLOADED
  CONFIRMED
  REJECTED
}

model GroupSupervision {
  id                  String                 @id @default(cuid())
  supervisorId        String
  supervisor          User                   @relation("SupervisorGroupSupervisions", fields: [supervisorId], references: [id])
  title               String
  description         String?
  scheduledDate       String
  scheduledTime       String
  duration            Int
  maxParticipants     Int                    @default(8)
  price               Float                  @default(0)
  currency            String                 @default("UAH")
  paymentInstructions String?
  zoomLink            String?
  zoomPassword        String?
  status              GroupSupervisionStatus @default(WAITING_FOR_CASE)
  recordingUrl        String?
  recordingExpiresAt  DateTime?
  presenterUserId     String?
  presenterUser       User?                  @relation("PresenterGroupSupervisions", fields: [presenterUserId], references: [id])
  caseTitle           String?
  caseDescription     String?
  supervisionFocus    String?
  protocolFileUrl     String?
  caseVideoUrl        String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  participants        GroupParticipant[]
  reminderSent3d      Boolean                @default(false)
  reminderSent1h      Boolean                @default(false)
  autoCompleteSent    Boolean                @default(false)
}

model GroupParticipant {
  id                 String                   @id @default(cuid())
  groupSupervisionId String
  groupSupervision   GroupSupervision         @relation(fields: [groupSupervisionId], references: [id], onDelete: Cascade)
  userId             String
  user               User                     @relation("UserGroupParticipations", fields: [userId], references: [id])
  paymentStatus      ParticipantPaymentStatus @default(PENDING)
  paymentReceiptUrl  String?
  ethicsConfirmed    Boolean                  @default(false)
  isPresenter        Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([groupSupervisionId, userId])
}

enum GroupSupervisionStatus {
  WAITING_FOR_CASE
  CASE_CONFIRMED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  WAITING_FOR_RECORDING
  RECORDING_AVAILABLE
  COMPLETED
}

enum ParticipantPaymentStatus {
  PENDING
  RECEIPT_UPLOADED
  CONFIRMED
  FREE
}

model CommunityPhrase {
  id          String        @id @default(cuid())
  text        String
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  savedBy     SavedPhrase[]
}

model SavedPhrase {
  id        String          @id @default(cuid())
  userId    String
  phraseId  String
  savedAt   DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  phrase    CommunityPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@unique([userId, phraseId])
}

model TherapistRequest {
  id             String                 @id @default(cuid())
  authorId       String
  author         User                   @relation("TherapistRequestAuthor", fields: [authorId], references: [id])
  title          String
  description    String
  workFormat     String?
  country        String?
  city           String?
  language       String?
  therapyFormats String[]
  price          Float?
  status         TherapistRequestStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  responses      TherapistResponse[]
}

model TherapistResponse {
  id           String           @id @default(cuid())
  requestId    String
  request      TherapistRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  therapistId  String
  therapist    User             @relation("TherapistResponseAuthor", fields: [therapistId], references: [id])
  presentation String
  links        String?
  isSelected   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([requestId, therapistId])
}

enum TherapistRequestStatus {
  OPEN
  CLOSED
}

model CommunityPost {
  id        String              @id @default(cuid())
  authorId  String
  author    User                @relation("CommunityAuthorPosts", fields: [authorId], references: [id])
  type      CommunityPostType
  title     String?
  content   String
  imageUrl  String?
  linkUrl   String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  reactions CommunityReaction[]
  comments  CommunityComment[]
}

enum CommunityPostType {
  REFLECTION
  QUESTION
  SUPPORT
  RESOURCE
}

model CommunityReaction {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("CommunityUserReactions", fields: [userId], references: [id])
  emoji     String
  createdAt DateTime      @default(now())

  @@unique([postId, userId, emoji])
}

model CommunityComment {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("CommunityCommentAuthor", fields: [authorId], references: [id])
  content   String
  isUseful  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
